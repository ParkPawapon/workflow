APP_ENV=production
APP_DEBUG=false

DB_HOST=127.0.0.1
DB_NAME=__SET_DATABASE_NAME__
DB_USER=__SET_DATABASE_USER__
DB_PASS=__SET_DATABASE_PASSWORD__
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_general_ci

UPLOAD_ROOT=storage/uploads
UPLOAD_MAX_BYTES=104857600

AUTH_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
SESSION_IDLE_TIMEOUT=7200
SESSION_ABSOLUTE_TIMEOUT=28800
